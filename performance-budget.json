  "assertions": {
    "categories:performance": ["error", { "minScore": 0.95 }],
    "categories:accessibility": ["error", { "minScore": 0.95 }],
    "categories:best-practices": ["error", { "minScore": 0.95 }],
    "categories:seo": ["error", { "minScore": 0.95 }],
    "audits:first-contentful-paint": ["error", { "maxNumericValue": 1800 }],
    "audits:largest-contentful-paint": ["error", { "maxNumericValue": 2500 }],
    "audits:first-input-delay": ["error", { "maxNumericValue": 100 }],
    "audits:cumulative-layout-shift": ["error", { "maxNumericValue": 0.1 }],
    "audits:time-to-interactive": ["error", { "maxNumericValue": 3500 }],
    "audits:total-blocking-time": ["error", { "maxNumericValue": 300 }],
    "audits:speed-index": ["error", { "maxNumericValue": 3400 }],
    "audits:uses-responsive-images": "error",
    "audits:uses-optimized-images": "error",
    "audits:modern-image-formats": "error",
    "audits:unused-css-rules": ["warn", { "maxLength": 2000 }],
    "audits:unused-javascript": ["warn", { "maxLength": 20000 }],
    "audits:render-blocking-resources": "error",
    "audits:unminified-css": "error",
    "audits:unminified-javascript": "error",
    "audits:efficient-animated-content": "error",
    "audits:uses-text-compression": "error",
    "audits:uses-rel-preconnect": "warn",
    "audits:uses-rel-preload": "warn",
    "audits:font-display": "error",
    "audits:critical-request-chains": ["warn", { "maxLength": 3 }],
    "audits:user-timings": "off",
    "audits:bootup-time": ["warn", { "maxNumericValue": 3500 }],
    "audits:mainthread-work-breakdown": ["warn", { "maxNumericValue": 4000 }],
    "audits:dom-size": ["warn", { "maxNumericValue": 1500 }],
    "audits:interactive": ["error", { "maxNumericValue": 3500 }],
    "audits:network-requests": "off",
    "audits:network-rtt": "off",
    "audits:network-server-latency": "off",
    "audits:main-thread-tasks": "off",
    "audits:diagnostics": "off",
    "audits:metrics": "off",
    "audits:screenshot-thumbnails": "off",
    "audits:final-screenshot": "off"
  },
  "settings": {
    "budgetPath": "./performance-budget.json",
    "preset": "desktop",
    "onlyCategories": ["performance", "accessibility", "best-practices", "seo"],
    "skipAudits": [
      "screenshot-thumbnails",
      "final-screenshot",
      "metrics",
      "diagnostics"
    ],
    "budgets": [
      {
        "path": "/*",
        "options": {
          "firstPartyHostnames": ["nosytlabs.com", "www.nosytlabs.com"],
          "requiredBudgets": ["performance", "accessibility"]
        }
      }
    ]
  }
}

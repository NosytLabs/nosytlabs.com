---
import TerminalLayout from '../layouts/TerminalLayout.astro';
---

<TerminalLayout>
  <div class="terminal-section">
    <h1 class="terminal-heading">NOSYT LABS BLOG</h1>
    <p class="terminal-paragraph">Insights, updates, and technical deep dives from our team.</p>
    
    <div class="terminal-grid">
      <div class="terminal-card">
        <div class="terminal-card-title">INTRODUCING OUR NEW PLATFORM</div>
        <div class="terminal-card-content">Learn about the innovative features and architecture of our latest release.</div>
        <div class="terminal-card-date">April 10, 2025</div>
      </div>
      
      <div class="terminal-card">
        <div class="terminal-card-title">PERFORMANCE OPTIMIZATION TECHNIQUES</div>
        <div class="terminal-card-content">Discover how we achieve sub-second load times and smooth animations.</div>
        <div class="terminal-card-date">March 28, 2025</div>
      </div>
      
      <div class="terminal-card">
        <div class="terminal-card-title">THE FUTURE OF INTERACTIVE UI</div>
        <div class="terminal-card-content">Exploring emerging trends in user interface design and implementation.</div>
        <div class="terminal-card-date">March 15, 2025</div>
      </div>
      
      <div class="terminal-card">
        <div class="terminal-card-title">BEHIND THE SCENES: OUR TECH STACK</div>
        <div class="terminal-card-content">A detailed look at the technologies powering our solutions.</div>
        <div class="terminal-card-date">February 22, 2025</div>
      </div>
    </div>
    
    <div class="terminal-navigation">
      <a href="/" class="terminal-button">RETURN TO MAIN MENU</a>
    </div>
  </div>
</TerminalLayout>

<style>
  .terminal-section {
    margin-bottom: 2rem;
  }
  
  .terminal-navigation {
    margin-top: 2rem;
    display: flex;
    justify-content: flex-start;
  }
  
  .terminal-card-date {
    margin-top: 0.5rem;
    font-size: 0.9rem;
    color: #999;
  }
</style>
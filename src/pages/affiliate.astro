</TerminalLayout>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    // Category filtering
    const categoryButtons = document.querySelectorAll('.affiliate-category-button');
    const affiliateItems = document.querySelectorAll('.affiliate-item');
    
    categoryButtons.forEach(button => {
      button.addEventListener('click', () => {
        // Remove active class from all buttons
        categoryButtons.forEach(btn => btn.classList.remove('active'));
        
        // Add active class to clicked button
        button.classList.add('active');
        
        const category = button.getAttribute('data-category');
        
        // Show/hide items based on category
        affiliateItems.forEach(item => {
          if (category === 'all' || item.getAttribute('data-category') === category) {
            item.style.display = 'block';
          } else {
            item.style.display = 'none';
          }
        });
      });
    });
    
    // Lazy loading for images
    const lazyImages = document.querySelectorAll('img.lazy-load');
    
    if ('IntersectionObserver' in window) {
      const imageObserver = new IntersectionObserver((entries, observer) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            const img = entry.target;
            img.src = img.dataset.src || img.src;
            img.classList.remove('lazy-load');
            imageObserver.unobserve(img);
          }
        });
      });
      
      lazyImages.forEach(img => {
        imageObserver.observe(img);
      });
    } else {
      // Fallback for browsers that don't support IntersectionObserver
      lazyImages.forEach(img => {
        img.src = img.dataset.src || img.src;
        img.classList.remove('lazy-load');
      });
    }
    
    // Affiliate link tracking
    const affiliateLinks = document.querySelectorAll('.affiliate-item-cta a');
    
    affiliateLinks.forEach(link => {
      link.addEventListener('click', function(e) {
        // Track click event if analytics is available
        if (window.trackEvent) {
          const productName = this.closest('.affiliate-item').querySelector('.affiliate-item-title').textContent;
          window.trackEvent('Affiliate', 'Click', productName);
        }
      });
    });
  });
</script>

<style>
  .affiliate-container {
    padding: 1rem 0;
  }
  
  .affiliate-disclaimer {
    margin: 2rem 0;
  }
  
  .affiliate-categories {
    margin: 2rem 0;
  }
  
  .affiliate-category-nav {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 1.5rem;
  }
  
  .affiliate-category-button {
    background-color: transparent;
    border: 1px solid var(--terminal-green);
    color: var(--terminal-green);
    padding: 0.5rem 1rem;
    cursor: pointer;
    font-family: 'Roboto Mono', monospace;
    transition: background-color 0.3s ease, color 0.3s ease;
  }
  
  .affiliate-category-button.active,
  .affiliate-category-button:hover {
    background-color: var(--terminal-green);
    color: var(--terminal-dark);
  }
  
  .affiliate-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
    margin: 2rem 0;
  }
  
  @media (min-width: 768px) {
    .affiliate-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  
  @media (min-width: 1200px) {
    .affiliate-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
  
  .affiliate-item {
    border: 1px solid var(--terminal-green);
    background-color: rgba(10, 10, 10, 0.8);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }
  
  .affiliate-item:hover {
    transform: translateY(-5px);
    box-shadow: 0 10px 20px rgba(51, 255, 51, 0.2);
  }
  
  .affiliate-item-header {
    padding: 1rem;
    border-bottom: 1px solid var(--terminal-green);
  }
  
  .affiliate-item-title {
    margin: 0 0 0.5rem 0;
    font-size: 1.2rem;
    color: var(--terminal-green);
  }
  
  .affiliate-item-badges {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }
  
  .affiliate-badge {
    background-color: rgba(51, 255, 51, 0.2);
    color: var(--terminal-green);
    padding: 0.2rem 0.5rem;
    font-size: 0.7rem;
    border-radius: 2px;
  }
  
  .affiliate-item-content {
    padding: 1rem;
  }
  
  .affiliate-item-image {
    margin-bottom: 1rem;
    border: 1px solid rgba(51, 255, 51, 0.3);
    overflow: hidden;
  }
  
  .affiliate-item-image img {
    width: 100%;
    height: auto;
    display: block;
    transition: transform 0.3s ease;
  }
  
  .affiliate-item-image:hover img {
    transform: scale(1.05);
  }
  
  .affiliate-item-description {
    margin-bottom: 1rem;
    font-size: 0.9rem;
    line-height: 1.5;
  }
  
  .affiliate-item-features {
    margin-bottom: 1.5rem;
  }
  
  .affiliate-item-features ul {
    padding-left: 1.5rem;
    margin: 0;
  }
  
  .affiliate-item-features li {
    margin-bottom: 0.5rem;
    font-size: 0.85rem;
  }
  
  .affiliate-item-cta {
    text-align: center;
  }
  
  .youtube-section {
    margin: 3rem 0;
    padding: 2rem;
    border: 1px solid var(--terminal-green);
    background-color: rgba(10, 10, 10, 0.8);
  }
  
  .youtube-embed {
    margin: 1.5rem 0;
  }
  
  .youtube-cta {
    text-align: center;
    margin-top: 1.5rem;
  }
  
  /* Lazy loading styles */
  img.lazy-load {
    opacity: 0;
    transition: opacity 0.3s ease;
  }
  
  img:not(.lazy-load) {
    opacity: 1;
  }
</style>

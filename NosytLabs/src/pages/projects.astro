</TerminalLayout>

<style>
  .projects-container {
    padding: 1rem 0;
  }
  
  .github-integration {
    margin: 2rem 0;
    border: 1px solid var(--terminal-green);
    padding: 1rem;
    background-color: rgba(10, 10, 10, 0.8);
  }
  
  .github-stats {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
  }
  
  .github-stat {
    font-size: 0.9rem;
  }
  
  .project-list {
    margin-top: 2rem;
  }
  
  .project-item {
    margin-bottom: 2rem;
    border: 1px solid var(--terminal-green-dark);
    padding: 1rem;
    background-color: rgba(10, 10, 10, 0.8);
    transition: all 0.3s ease;
  }
  
  .project-item:hover {
    border-color: var(--terminal-green);
    box-shadow: 0 0 10px rgba(76, 175, 80, 0.3);
  }
  
  .project-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--terminal-green-dark);
  }
  
  .project-badges {
    display: flex;
    gap: 0.5rem;
  }
  
  .project-badge {
    background-color: var(--terminal-gray);
    color: var(--terminal-green-light);
    padding: 0.2rem 0.5rem;
    font-size: 0.7rem;
    border: 1px solid var(--terminal-green-dark);
  }
  
  .project-content {
    padding: 0.5rem 0;
  }
  
  .project-stats {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    margin: 1rem 0;
  }
  
  .project-stat {
    font-size: 0.8rem;
  }
  
  .stat-label {
    color: var(--terminal-green-light);
    margin-right: 0.5rem;
  }
  
  .project-links {
    display: flex;
    gap: 0.5rem;
    margin-top: 1rem;
  }
  
  .project-details-modal {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: rgba(0, 0, 0, 0.8);
    display: flex;
    justify-content: center;
    align-items: center;
    z-index: 100;
  }
  
  .modal-content {
    background-color: var(--terminal-black);
    border: 1px solid var(--terminal-green);
    width: 80%;
    max-width: 800px;
    max-height: 80vh;
    overflow-y: auto;
  }
  
  .modal-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1rem;
    border-bottom: 1px solid var(--terminal-green-dark);
  }
  
  .modal-close {
    background: none;
    border: none;
    color: var(--terminal-green);
    font-size: 1.5rem;
    cursor: pointer;
  }
  
  .modal-body {
    padding: 1rem;
  }
  
  .modal-footer {
    padding: 1rem;
    border-top: 1px solid var(--terminal-green-dark);
    text-align: right;
  }
  
  .hidden {
    display: none;
  }
.video-container {
  position: relative;
  padding-bottom: 56.25%; /* 16:9 aspect ratio */
  height: 0;
  overflow: hidden;
  max-width: 100%;
  margin-top: 1rem;
}

.video-container iframe {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  border: 0;
}
</style>

<script>
  import { gsap } from 'gsap';
  
  document.addEventListener('DOMContentLoaded', () => {
    // GitHub integration loading animation
    const githubLoading = document.getElementById('github-loading');
    const githubData = document.getElementById('github-data');
    
    // Simulate GitHub API connection
    setTimeout(() => {
      gsap.to(githubLoading, {
        opacity: 0,
        duration: 0.5,
        onComplete: () => {
          githubLoading.classList.add('hidden');
          githubData.classList.remove('hidden');
          
          // Animate GitHub data
          gsap.from(githubData, {
            opacity: 0,
            y: -20,
            duration: 0.5
          });
          
          // Animate GitHub stats with counting effect
          const repoCount = document.getElementById('repo-count');
          const commitCount = document.getElementById('commit-count');
          const contributorCount = document.getElementById('contributor-count');
          
          gsap.from(repoCount, {
            innerText: 0,
            duration: 2,
            snap: { innerText: 1 }
          });
          
          gsap.from(commitCount, {
            innerText: 0,
            duration: 2,
            snap: { innerText: 1 }
          });
          
          gsap.from(contributorCount, {
            innerText: 0,
            duration: 2,
            snap: { innerText: 1 }
          });
        }
      });
    }, 2000);
    
    // Project items animation
    const projectItems = document.querySelectorAll('.project-item');
    gsap.from(projectItems, {
      opacity: 0,
      y: 20,
      duration: 0.5,
      stagger: 0.2,
      delay: 2.5
    });
    
    // Project details modal
    const projectDetailsButtons = document.querySelectorAll('.project-details-btn');
    const projectDetailsModal = document.getElementById('project-details-modal');
    const modalTitle = document.getElementById('modal-title');
    const modalBody = document.getElementById('modal-body');
    const modalClose = document.getElementById('modal-close');
    const modalCloseBtn = document.getElementById('modal-close-btn');
    
    // Project details data
    const projectDetails = {
      'stream-companion': {
        title: 'STREAM COMPANION',
        description: `The Stream Companion is an AI-powered streaming chat bot designed to enhance the streaming experience for content creators and viewers alike. Unlike traditional chat bots, Stream Companion doesn't require users to keep the application open, as it functions as a server that continuously monitors streaming chats.
        
        Key features include:
        - Intelligent chat moderation with customizable rules
        - Viewer engagement tools and automated responses
        - Stream analytics and viewer behavior insights
        - Custom command creation and management
        - Integration with popular streaming platforms
        - Scheduled announcements and reminders
        
        The application leverages advanced natural language processing to understand context and provide relevant responses, creating a more interactive and engaging streaming environment.`,
        technologies: ['Python', 'TensorFlow', 'Node.js', 'WebSockets', 'Twitch API', 'YouTube API'],
      }
    };
  });
</script>
        },
`,
          </div>
        </div>
      </div>
      
      <div class="project-item" data-repo="vault-shelter-game">
        <div class="project-header">
          <h2 class="terminal-subheading">VAULT SHELTER GAME</h2>
          <div class="project-badges">
            <span class="project-badge">GAME</span>
            <span class="project-badge">BLOCKCHAIN</span>
            <span class="project-badge">NFT</span>
          </div>
        </div>
        

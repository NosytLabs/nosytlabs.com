---
import TerminalLayout from '../layouts/TerminalLayout.astro';
---

<TerminalLayout>
  <div class="projects-container">
    <h1 class="terminal-heading">PROJECTS</h1>
    <p class="terminal-paragraph">
      Explore Nosyt Labs' innovative projects across AI, web development, game design, and blockchain technology.
      Check out our YouTube channel for project demos, tutorials, and the latest updates.
    </p>
    
    <div class="github-integration" id="github-integration">
      <div class="terminal-loading" id="github-loading">CONNECTING TO GITHUB API...</div>
      
      <div class="github-data hidden" id="github-data">
        <div class="terminal-card">
          <div class="terminal-card-title">GITHUB REPOSITORY STATUS</div>
          <div class="terminal-card-content">
            <div class="github-stats">
              <div class="github-stat">ORGANIZATION: <span id="org-name">NosytLabs</span></div>
              <div class="github-stat">REPOSITORIES: <span id="repo-count">5</span></div>
              <div class="github-stat">TOTAL COMMITS: <span id="commit-count">237</span></div>
              <div class="github-stat">CONTRIBUTORS: <span id="contributor-count">3</span></div>
              <div class="github-stat">LAST UPDATED: <span id="last-updated">2025-03-25T14:32:17Z</span></div>
            </div>
          </div>
        </div>
      </div>
    </div>
    
    <div class="project-list" id="project-list">
<div class="project-item" data-repo="youtube-channel">
  <div class="project-header">
    <h2 class="terminal-subheading">
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="var(--terminal-green-light)" style="vertical-align: middle; margin-right: 0.5rem;">
        <path d="M19.615 3.184C21.403 3.58 22.5 5.053 22.5 7.5v9c0 2.447-1.097 3.92-2.885 4.316-2.53.58-10.115.58-10.115.58s-7.585 0-10.115-.58C.597 20.42-.5 18.947-.5 16.5v-9c0-2.447 1.097-3.92 2.885-4.316C2.915 2.604 10.5 2.604 10.5 2.604s7.585 0 9.115.58zM9.5 8.5v7l6-3.5-6-3.5z"/>
      </svg>
      YOUTUBE CHANNEL
    </h2>
    <div class="project-badges">
      <span class="project-badge">VIDEO</span>
      <span class="project-badge">TUTORIALS</span>
      <span class="project-badge">FEATURED</span>
    </div>
  </div>
  <div class="project-content">
    <p class="terminal-paragraph">Subscribe to our YouTube channel for project demos, tutorials, behind-the-scenes content, and the latest updates from Nosyt Labs.</p>
    <div class="project-links">
      <a href="https://www.youtube.com/user/tycenyt" class="terminal-button" target="_blank" rel="noopener noreferrer" id="youtube-link">VISIT CHANNEL</a>
    </div>
    <div class="video-container" style="margin-top:1rem;">
      <iframe src="https://www.youtube.com/embed/dQw4w9WgXcQ" title="Nosyt Labs YouTube" allowfullscreen></iframe>
    </div>
    <script>
      document.addEventListener('DOMContentLoaded', () => {
        const ytLink = document.getElementById('youtube-link');
        if (ytLink) {
          console.log('YouTube link found:', ytLink.href);
          ytLink.addEventListener('click', (e) => {
            console.log('YouTube link clicked');
            console.log('target:', ytLink.target);
            console.log('rel:', ytLink.rel);
          });
        } else {
          console.warn('YouTube link not found');
        }
      });
    </script>
  </div>
</div>
      <div class="project-item" data-repo="stream-companion">

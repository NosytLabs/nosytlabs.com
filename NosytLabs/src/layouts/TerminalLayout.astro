---
import '../styles/global.css';
import { ViewTransitions } from 'astro:transitions';
import DropdownNav from '../components/DropdownNav.astro';
import Analytics from '@vercel/analytics/astro';
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="icon" type="image/png" href="/images/logo.svg" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Share+Tech+Mono&display=swap" rel="stylesheet" />
  <ViewTransitions />
  <title>Nosyt Labs - Notable Opportunities Shape Your Tomorrow</title>
  <meta name="description" content="Nosyt Labs is a forward-thinking technology company specializing in innovative solutions across multiple domains." />
  <meta property="og:title" content="Nosyt Labs - Notable Opportunities Shape Your Tomorrow" />
  <meta property="og:description" content="Nosyt Labs is a forward-thinking technology company specializing in innovative solutions across multiple domains." />
  <meta property="og:url" content="https://nosytlabs.com/" />
  <meta property="og:image" content="/images/nosyt-labs-og.png" />
  <meta property="og:type" content="website" />
  <meta name="keywords" content="technology, innovation, software, development" />
  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": "Nosyt Labs",
      "url": "https://nosytlabs.com/",
      "logo": "/images/nosyt-labs-og.png"
    }
  </script>

  <!-- Service Worker Registration -->
  <script>
    if ('serviceWorker' in navigator) {
      window.addEventListener('load', () => {
        navigator.serviceWorker.register('/service-worker.js')
          .then(registration => {
            console.log('Service Worker registered with scope:', registration.scope);
          })
          .catch(error => {
            console.error('Service Worker registration failed:', error);
          });
      });
    }
  </script>
</head>
<body class="terminal-background">
  <a href="#main-content" class="skip-link">Skip to main content</a>

  <!-- RobCo Loading Overlay removed: now only on home page -->

  <div class="terminal-scanline"></div>
  <div class="terminal-noise"></div>
  <div id="terminal-background-container"></div>
  <div id="terminal-effects-container"></div>

  <div class="layout-container">
    <header>
      <nav role="navigation" aria-label="Main navigation">
        <DropdownNav />
      </nav>
    </header>

    <main id="main-content" class="main-content">
      <div class="terminal-wrapper">
        <div class="terminal-container">
          <header class="terminal-header">
            <div class="terminal-title">ROBCO INDUSTRIES (TM) TERMLINK PROTOCOL</div>
            <nav aria-label="Terminal navigation">
              <DropdownNav />
            </nav>
          </header>

          <div class="terminal-content">
            <!-- Optional: terminal output area -->
          </div>

          <div id="terminal-interactive-container"></div>
          <div id="terminal-cli-container"></div>

          <footer class="terminal-footer">
            <div class="terminal-commands">
              [TAB] EXIT &nbsp;&nbsp; [R] LOAD HOLOTAPE &nbsp;&nbsp; [H] HELP
            </div>
            <div class="terminal-copyright">
              &copy; 2025 Nosyt Labs - Notable Opportunities Shape Your Tomorrow
            </div>
          </footer>
        </div>
      </div>
    </main>

  </div>

  <script>
    document.addEventListener('DOMContentLoaded', () => {
      console.log('Terminal initialized');

      import('../scripts/terminal-background.js').then(module => {
        const { TerminalBackground } = module;
        const background = new TerminalBackground('terminal-background-container');
        background.initialize();
      }).catch(err => {
        console.error('Failed to load terminal background:', err);
      });

      import('../scripts/terminal-effects.js').then(module => {
        const { TerminalEffects } = module;
        const effects = new TerminalEffects('terminal-effects-container');
        effects.initialize();
      }).catch(err => {
        console.error('Failed to load terminal effects:', err);
      });

      import('../scripts/theme-manager.js').then(module => {
        const { ThemeManager } = module;
        const themeManager = new ThemeManager();
        themeManager.initialize(true);
      }).catch(err => {
        console.error('Failed to load theme manager:', err);
      });

      import('../scripts/terminal-cli.js').then(module => {
        const { TerminalCLI } = module;
        const cli = new TerminalCLI('terminal-cli-container');
        cli.initialize();
        // Removed overlay hide logic since overlay is now only on home page
      }).catch(err => {
        console.error('Failed to load terminal CLI:', err);
      });

      import('../scripts/seo-manager.js').then(module => {
        const { SEOManager } = module;
        const seo = new SEOManager();
      }).catch(err => {
        console.error('Failed to load SEO manager:', err);
      });

      import('../scripts/blog-manager.js').then(module => {
        const { BlogManager } = module;
        const blog = new BlogManager();
        blog.initialize();
      }).catch(err => {
        console.error('Failed to load blog manager:', err);
      });

      document.addEventListener('terminal-object-click', (event) => {
        console.log('Terminal object clicked:', event.detail.id);
      });
    });
  </script>
  <Analytics />
</body>
</html>
